# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE CONFIGURATION
# FIREBASE_SERVICE_ACCOUNT: JSON string of the Firebase Service Account Key.
# Required for server-side Firebase Admin SDK operations (e.g. Backups, Auth, Webhooks).
FIREBASE_SERVICE_ACCOUNT=

# PAYMENT GATEWAYS
ASAAS_API_KEY=
ASAAS_SANDBOX=false
# Chave Webhook do Asaas (para validar origem do webhook)
ASAAS_WEBHOOK_TOKEN=
ASAAS_WEBHOOK_SECRET=
ASAAS_MASTER_WALLET_ID=

# WHATSAPP INTEGRATION (Ex: Z-API, Evolution, Meta)
VITE_WHATSAPP_API_URL=
VITE_WHATSAPP_API_TOKEN=

# DOCUMENT SIGNATURE INTEGRATION
ZAPSIGN_API_TOKEN=
ASSINAFY_API_KEY=sk_live_sua_chave_gerada_no_painel_do_assinafy

# DAILY BACKUP / SCHEDULED TASKS SECURITY
# A secret token to validate requests coming from Google Cloud Scheduler.
# Configure this in Cloud Run environment variables and Scheduler headers as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# SMTP Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=no-reply@seu-dominio.com
EMAIL_PASS=sua_senha

