{
  "firestore": [
    {
      "database": "ai-studio-4551b9d4-cbf8-4a88-96e4-47c6d55b185b",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "(default)",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
